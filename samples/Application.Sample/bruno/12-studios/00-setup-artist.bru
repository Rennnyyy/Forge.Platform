meta {
  name: Studios - setup artist (POST)
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/api/entities/artists
  body: json
  auth: none
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "name": "Studio Artist",
    "country": "DE",
    "bio": "House artist for Sonic Forge Studios.",
    "active": true,
    "debutYear": 2010
  }
}

assert {
  res.status: eq 200
  res.body.iri: isDefined
}

script:post-response {
  bru.setVar("artistIri", res.body.iri);
}
