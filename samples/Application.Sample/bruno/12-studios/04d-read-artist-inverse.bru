meta {
  name: Studios - read artist inverse collection (GET ?iri= artist sees managing studio)
  type: http
  seq: 9
}

get {
  url: {{baseUrl}}/api/entities/artists?iri={{artistIri}}
  body: none
  auth: none
}

assert {
  res.status: eq 200
  res.body.iri: isDefined
  res.body.managedStudios: contains {{studioIri}}
}
