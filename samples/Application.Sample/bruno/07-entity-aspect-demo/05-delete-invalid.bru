meta {
  name: Entity aspect demo - delete checked-out book → 422
  type: http
  seq: 5
}

delete {
  url: {{baseUrl}}/api/entities/books?iri={{checkedOutBookIri}}
  body: none
  auth: none
}

headers {
  X-Forge-Operation-AspectIri: urn:forge:aspects:operation:book-delete-v1
}

assert {
  res.status: eq 422
  res.body.code: eq ENTITY_SHACL_VIOLATION
}
