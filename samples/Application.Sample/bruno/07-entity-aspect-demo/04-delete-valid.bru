meta {
  name: Entity aspect demo - delete available book → 200
  type: http
  seq: 4
}

delete {
  url: {{baseUrl}}/api/entities/books?iri={{entityAspectBookIri}}
  body: none
  auth: none
}

headers {
  X-Forge-Operation-AspectIri: urn:forge:aspects:operation:book-delete-v1
}

assert {
  res.status: eq 200
}
