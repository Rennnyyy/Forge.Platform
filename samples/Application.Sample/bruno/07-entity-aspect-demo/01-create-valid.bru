meta {
  name: Entity aspect demo - create valid book (year >= 1800)
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/api/entities/books
  body: json
  auth: none
}

headers {
  Content-Type: application/json
  X-Forge-Operation-AspectIri: urn:forge:aspects:operation:book-write-v1
}

body:json {
  {
    "isbn": "aspect-test-001",
    "title": "Modern Software Engineering",
    "author": "David Farley",
    "publishedYear": 2021,
    "available": true
  }
}

assert {
  res.status: eq 200
  res.body.iri: isDefined
}

script:post-response {
  bru.setVar("entityAspectBookIri", res.body.iri);
}
