meta {
  name: Structure tree - create Combustion Engine node
  type: http
  seq: 6
}

post {
  url: {{baseUrl}}/api/entities/structure-nodes
  body: json
  auth: none
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "name": "Combustion Engine",
    "description": "Turbocharged four-cylinder petrol engine"
  }
}

assert {
  res.status: eq 200
  res.body.iri: isDefined
}

script:post-response {
  bru.setVar("combustionEngineIri", res.body.iri);
}
