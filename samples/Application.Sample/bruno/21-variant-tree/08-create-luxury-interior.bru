meta {
  name: Structure tree - create Luxury Interior node
  type: http
  seq: 8
}

post {
  url: {{baseUrl}}/api/entities/structure-nodes
  body: json
  auth: none
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "name": "Luxury Interior",
    "description": "Nappa leather seats, ambient lighting, panoramic roof"
  }
}

assert {
  res.status: eq 200
  res.body.iri: isDefined
}

script:post-response {
  bru.setVar("luxuryInteriorIri", res.body.iri);
}
