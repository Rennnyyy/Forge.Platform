meta {
  name: Structure tree - create EV flag dimension
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/api/entities/structure-dimensions
  body: json
  auth: none
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "name": "EV Powertrain",
    "type": "Flag",
    "description": "Boolean flag: true = electric vehicle, false = ICE vehicle"
  }
}

assert {
  res.status: eq 200
  res.body.iri: isDefined
}

script:post-response {
  bru.setVar("evDimensionIri", res.body.iri);
}
