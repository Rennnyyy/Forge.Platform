meta {
  name: Structure tree - create ICE Powertrain node
  type: http
  seq: 3
}

post {
  url: {{baseUrl}}/api/entities/structure-nodes
  body: json
  auth: none
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "name": "ICE Powertrain",
    "description": "Internal combustion engine powertrain assembly"
  }
}

assert {
  res.status: eq 200
  res.body.iri: isDefined
}

script:post-response {
  bru.setVar("icePowertrainIri", res.body.iri);
}
