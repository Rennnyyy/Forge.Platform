meta {
  name: Structure tree - create Gearbox node
  type: http
  seq: 7
}

post {
  url: {{baseUrl}}/api/entities/structure-nodes
  body: json
  auth: none
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "name": "Gearbox",
    "description": "Eight-speed automatic transmission"
  }
}

assert {
  res.status: eq 200
  res.body.iri: isDefined
}

script:post-response {
  bru.setVar("gearboxIri", res.body.iri);
}
