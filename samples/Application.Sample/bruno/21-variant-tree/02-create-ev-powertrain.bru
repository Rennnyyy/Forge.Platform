meta {
  name: Structure tree - create EV Powertrain node
  type: http
  seq: 2
}

post {
  url: {{baseUrl}}/api/entities/structure-nodes
  body: json
  auth: none
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "name": "EV Powertrain",
    "description": "Electric vehicle powertrain assembly"
  }
}

assert {
  res.status: eq 200
  res.body.iri: isDefined
}

script:post-response {
  bru.setVar("evPowertrainIri", res.body.iri);
}
