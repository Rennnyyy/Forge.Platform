meta {
  name: Studio relations - bad enumeration IRI (M:N genres → 422)
  type: http
  seq: 6
}

post {
  url: {{baseUrl}}/api/capabilities/demo/studio/create-linked
  body: json
  auth: none
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "name": "Relations Demo Studio (bad genre)",
    "foundedYear": 2010,
    "genreIris": ["https://forge-it.net/genres/not-a-real-genre"]
  }
}

assert {
  res.status: eq 422
  res.body.code: eq RELATION_NOT_FOUND
}
