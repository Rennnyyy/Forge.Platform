meta {
  name: TrackMasters - create branch for remix work (POST)
  type: http
  seq: 14
}

post {
  url: {{baseUrl}}/api/branches
  body: json
  auth: none
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "name": "remix-v2",
    "description": "Branch for remix master candidate v2"
  }
}

assert {
  res.status: eq 200
  res.body.iri: isDefined
}

script:post-response {
  bru.setVar("remixBranchIri", res.body.iri);
}
