meta {
  name: Books - read (GET ?iri=)
  type: http
  seq: 2
}

get {
  url: {{baseUrl}}/api/entities/books?iri={{bookIri}}
  body: none
  auth: none
}

assert {
  res.status: eq 200
  res.body.iri: isDefined
  res.body.isbn: eq 978-0-201-37962-4
  res.body.title: contains Pragmatic
  res.body.available: eq true
}
