meta {
  name: Books - update (PUT ?iri=)
  type: http
  seq: 3
}

put {
  url: {{baseUrl}}/api/entities/books?iri={{bookIri}}
  body: json
  auth: none
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "isbn": "978-0-201-37962-4",
    "title": "The Pragmatic Programmer (20th Anniversary Edition)",
    "author": "David Thomas, Andrew Hunt",
    "publishedYear": 2019,
    "available": false
  }
}

assert {
  res.status: eq 200
  res.body.iri: isDefined
}
