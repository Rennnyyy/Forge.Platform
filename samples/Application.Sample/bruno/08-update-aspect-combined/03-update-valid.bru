meta {
  name: Update aspect combined - update valid book (SHACL + WHERE both pass)
  type: http
  seq: 3
}

put {
  url: {{baseUrl}}/api/entities/books?iri={{availableBookIri}}
  body: json
  auth: none
}

headers {
  Content-Type: application/json
  X-Forge-Operation-AspectIri: urn:forge:aspects:operation:book-update-strict-v1
}

body:json {
  {
    "isbn": "strict-update-001",
    "title": "Available Book (Updated)",
    "author": "Test Author",
    "publishedYear": 2022,
    "available": true
  }
}

assert {
  res.status: eq 200
}
