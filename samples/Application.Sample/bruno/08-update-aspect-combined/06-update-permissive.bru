meta {
  name: Update aspect combined - permissive (no aspect header bypasses all checks)
  type: http
  seq: 6
}

put {
  url: {{baseUrl}}/api/entities/books?iri={{checkedOutBookIri2}}
  body: json
  auth: none
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "isbn": "strict-update-002",
    "title": "Checked Out Book (Bypassed)",
    "author": "Test Author",
    "publishedYear": 1450,
    "available": false
  }
}

assert {
  res.status: eq 200
}
