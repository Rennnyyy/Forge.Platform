meta {
  name: Snapshots - create source branch (POST)
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/api/branches
  body: json
  auth: none
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "name": "snapshot-source",
    "description": "Branch to be captured as an immutable snapshot"
  }
}

assert {
  res.status: eq 200
  res.body.iri: isDefined
}

script:post-response {
  bru.setVar("sourceBranchIri", res.body.iri);
}
