meta {
  name: Car demo - read Car root node via entity CRUD
  type: http
  seq: 8
}

get {
  url: {{baseUrl}}/api/entities/structure-nodes?iri={{carIri}}
  body: none
  auth: none
}

headers {
  X-Forge-BranchIri: https://forge-it.net/branches/main
}

assert {
  res.status: eq 200
  res.body.name: eq "Demo Car"
}
