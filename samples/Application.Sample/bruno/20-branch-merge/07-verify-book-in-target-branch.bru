meta {
  name: Branch merge - verify book propagated to target (GET)
  type: http
  seq: 7
}

get {
  url: {{baseUrl}}/api/entities/books?iri={{mergeBookIri}}
  body: none
  auth: none
}

headers {
  X-Forge-BranchIri: {{mergeTgtIri}}
}

assert {
  res.status: eq 200
  res.body.isbn: eq 978-0-20-161622-4
  res.body.title: contains Pragmatic Programmer
}
