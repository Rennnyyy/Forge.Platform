meta {
  name: Branch merge - create source branch (POST)
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/api/branches
  body: json
  auth: none
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "name": "merge-source",
    "description": "Source branch for merge demo"
  }
}

assert {
  res.status: eq 200
  res.body.iri: isDefined
}

script:post-response {
  bru.setVar("mergeSrcIri", res.body.iri);
}
