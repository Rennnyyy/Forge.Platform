meta {
  name: Branches - read (GET ?iri=)
  type: http
  seq: 2
}

get {
  url: {{baseUrl}}/api/branches?iri={{branchIri}}
  body: none
  auth: none
}

vars:pre-request {
  branchIri: https://forge-it.net/branches/feature-demo
}

assert {
  res.status: eq 200
  res.body.iri: isDefined
  res.body.name: eq feature-demos
  res.body.description: contains Demo branch
}
