meta {
  name: Branch aspect demo - create branch with short description → 422
  type: http
  seq: 3
}

post {
  url: {{baseUrl}}/api/branches
  body: json
  auth: none
}

headers {
  Content-Type: application/json
  X-Forge-Operation-AspectIri: urn:forge:aspects:operation:branch-write-v1
}

body:json {
  {
    "name": "aspect-demo-bad",
    "description": "Hi"
  }
}

assert {
  res.status: eq 422
  res.body.code: eq ENTITY_SHACL_VIOLATION
}
