meta {
  name: Branch aspect demo - create branch without aspect (no constraints)
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/api/branches
  body: json
  auth: none
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "name": "aspect-demo-free"
  }
}

assert {
  res.status: eq 200
  res.body.iri: isDefined
}

script:post-response {
  bru.setVar("branchFreeIri", res.body.iri);
}
