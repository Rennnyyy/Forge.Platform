meta {
  name: Entity Messaging - create branch (setup)
  type: http
  seq: 10
}

post {
  url: {{baseUrl}}/api/branches
  body: json
  auth: none
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "name": "messaging-demo-branch",
    "description": "Branch created by the entity messaging Bruno demo"
  }
}

assert {
  res.status: eq 200
  res.body.iri: isDefined
}

script:post-response {
  bru.setVar("messagingBranchIri", res.body.iri);
}
