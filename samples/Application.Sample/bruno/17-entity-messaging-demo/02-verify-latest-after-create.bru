meta {
  name: Entity Messaging - read latest state (Created)
  type: http
  seq: 3
}

get {
  url: {{baseUrl}}/api/diagnostics/entity-events/latest?iri={{messagingBookIri}}
  body: none
  auth: none
}

assert {
  res.status: eq 200
  res.body.entityIri: eq {{messagingBookIri}}
  res.body.typeName: eq Book
  res.body.operation: eq Created
  res.body.topic: eq forge.entities.book.state
  res.body.timestampUtc: isDefined
}
